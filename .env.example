# Personal Cognitive Digital Twin - Environment Variables
# Copy this file to .env and fill in your values

# GenAI API Keys (choose one based on your config/default.json provider setting)
# OpenRouter (recommended - free tier available): https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (premium option): https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Optional settings
LOG_LEVEL=INFO
DEBUG=false
